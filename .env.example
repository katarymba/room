# Room — Environment Variables
# Copy to .env and fill in the values:
#   cp .env.example .env

# -------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -------------------------------------------------------------------
POSTGRES_USER=room
# IMPORTANT: Use a strong password (≥ 16 characters) in production
POSTGRES_PASSWORD=replace-with-strong-password-min-16-chars
POSTGRES_DB=room

# Used by the backend service; host is "postgres" inside Docker
DATABASE_URL=postgresql://room:replace-with-strong-password-min-16-chars@postgres:5432/room

# -------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters long and not a weak/default value
SECRET_KEY=replace-with-output-of-secrets-token-hex-32
ALGORITHM=HS256

# Access token lifetime (minutes). Recommended: 15–60
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime (days). Recommended: 30
REFRESH_TOKEN_EXPIRE_DAYS=30

DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Comma-separated list of allowed CORS origins (JSON array format as expected by pydantic-settings)
# Remove wildcard and restrict to your actual frontend origins in production
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8000"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# -------------------------------------------------------------------
# Redis (rate limiting, caching, pub/sub)
# -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------------
# pgAdmin
# -------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@room.local
PGADMIN_DEFAULT_PASSWORD=admin

# -------------------------------------------------------------------
# Mobile (for reference — used in mobile/.env)
# -------------------------------------------------------------------
API_URL=http://localhost:8000
