# Room — Environment Variables
# Copy to .env and fill in the values:
#   cp .env.example .env

# -------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -------------------------------------------------------------------
POSTGRES_USER=room
# Must be ≥ 16 characters. Avoid: admin, 1234, changeme, password
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change-me-strong-password-16chars
POSTGRES_DB=room

# Used by the backend service; host is "postgres" inside Docker
DATABASE_URL=postgresql://room:change-me-strong-password-16chars@postgres:5432/room

# -------------------------------------------------------------------
# Redis (rate limiting & pub/sub)
# -------------------------------------------------------------------
# Used by the backend service; host is "redis" inside Docker
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be ≥ 32 characters. Application will refuse to start with weak keys.
SECRET_KEY=generate-random-64-char-key-here-must-be-at-least-32-chars
ALGORITHM=HS256
# Access token lifetime (15–60 minutes recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=30

DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Comma-separated list of allowed CORS origins (JSON array format as expected by pydantic-settings)
# In production, replace with your actual domain(s):
CORS_ORIGINS=["https://your-app.example.com"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# -------------------------------------------------------------------
# pgAdmin
# -------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@room.local
PGADMIN_DEFAULT_PASSWORD=admin

# -------------------------------------------------------------------
# Mobile (for reference — used in mobile/.env)
# -------------------------------------------------------------------
API_URL=http://localhost:8000
