# Room — Environment Variables
# Copy to .env and fill in the values:
#   cp .env.example .env

# -------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -------------------------------------------------------------------
POSTGRES_USER=room
POSTGRES_PASSWORD=changeme
POSTGRES_DB=room

# Used by the backend service; host is "postgres" inside Docker
DATABASE_URL=postgresql://room:changeme@postgres:5432/room

# -------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8000"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# -------------------------------------------------------------------
# pgAdmin
# -------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@room.local
PGADMIN_DEFAULT_PASSWORD=admin

# -------------------------------------------------------------------
# Mobile (for reference — used in mobile/.env)
# -------------------------------------------------------------------
API_URL=http://localhost:8000
