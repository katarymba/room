# Room — Environment Variables
# Copy to .env and fill in the values:
#   cp .env.example .env

# -------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -------------------------------------------------------------------
POSTGRES_USER=room
# REQUIRED: Set a strong password (min 16 chars, no weak defaults).
# Generate one with: python -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=room

# Used by the backend service; host is "postgres" inside Docker.
# IMPORTANT: Use the same password here as in POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://room:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/room

# -------------------------------------------------------------------
# Backend
# -------------------------------------------------------------------
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Comma-separated list of allowed CORS origins (JSON array format as expected by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8000"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# -------------------------------------------------------------------
# pgAdmin
# -------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@room.local
# REQUIRED: Set a strong password before deploying.
PGADMIN_DEFAULT_PASSWORD=REPLACE_WITH_PGADMIN_PASSWORD

# -------------------------------------------------------------------
# Mobile (for reference — used in mobile/.env)
# -------------------------------------------------------------------
API_URL=http://localhost:8000
