# Environment variables for Room Backend
# Copy this file to .env and fill in the values

# Application
DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Database (PostgreSQL with PostGIS extension)
DATABASE_URL=postgresql://room_user:change-me-strong-password@localhost:5432/room_db
# Must be ≥ 16 characters. Avoid: admin, 1234, changeme, password
POSTGRES_PASSWORD=change-me-strong-password-16chars

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# Must be ≥ 32 characters. Application refuses to start with weak keys.
SECRET_KEY=generate-random-64-char-key-here-must-be-at-least-32-chars
ALGORITHM=HS256
# Access token lifetime (15–60 minutes recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — in production replace with your actual domain(s)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# Redis (rate limiting, session storage)
# In Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# SMS Provider (optional for MVP)
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM_NUMBER=

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://yourapp.com/subscription/success
STRIPE_CANCEL_URL=https://yourapp.com/subscription/cancel

# Payments (RevenueCat — mobile)
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_AUTH_HEADER=

# Analytics
MIXPANEL_TOKEN=
POSTHOG_API_KEY=

# Error tracking (Sentry)
SENTRY_DSN=
ENVIRONMENT=development
