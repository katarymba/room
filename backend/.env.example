# Environment variables for Room Backend
# Copy this file to .env and fill in the values

# Application
DEBUG=False
APP_NAME=Room API
APP_VERSION=0.1.0

# Database (PostgreSQL with PostGIS extension)
DATABASE_URL=postgresql://room_user:room_pass@localhost:5432/room_db

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# Geolocation defaults
DEFAULT_RADIUS_METERS=100
MAX_RADIUS_METERS=200

# SMS Provider (optional for MVP)
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM_NUMBER=

# Redis (used by rate limiter; optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Rate limits
RATE_LIMIT_LOCATION_UPDATES=1
RATE_LIMIT_LOCATION_WINDOW_SECONDS=60
FREE_DAILY_MESSAGE_LIMIT=20

# WebSocket auth handshake timeout in seconds
WS_AUTH_TIMEOUT_SECONDS=5.0
